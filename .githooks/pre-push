#!/usr/bin/env bash
# pre-push — run the FULL CI gate before every push so "passes locally" and
# "passes CI" cannot diverge. Delegates to scripts/ci-gate.sh, which mirrors
# .github/workflows/ci.yml command-for-command (fmt + clippy + the light facade
# lint + `cargo test` + the whitespace check).
#
# Enable once per clone with:
#   git config core.hooksPath .githooks
#
# Fast path: a clippy/test pass can take a while. For a quick push of a trivial
# change, set MODAL_RUST_FAST_PUSH=1 to run only the FAST half (fmt + clippy, no
# tests). Use sparingly — it is what lets a deterministic test failure reach CI.
#   MODAL_RUST_FAST_PUSH=1 git push
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

RUST_TOOLCHAIN="1.96.0" # keep in lockstep with ci.yml + rust-toolchain.toml

if [[ "${MODAL_RUST_FAST_PUSH:-0}" == "1" ]]; then
  echo "pre-push: FAST mode (MODAL_RUST_FAST_PUSH=1) — fmt + clippy only, SKIPPING tests"
  cargo +"$RUST_TOOLCHAIN" fmt --check
  cargo +"$RUST_TOOLCHAIN" clippy --all-targets -- -D warnings
  cargo +"$RUST_TOOLCHAIN" clippy -p modal-rust -p modal-rust-macros -- -D warnings
  echo "pre-push: fast gate green (tests NOT run — CI still runs them)."
  exit 0
fi

echo "pre-push: running the full CI gate (scripts/ci-gate.sh) — set MODAL_RUST_FAST_PUSH=1 to skip tests"
exec scripts/ci-gate.sh

#!/usr/bin/env bash
# pre-push — FAST by default: catch the trivially-fixable stuff without paying a
# cargo compile, and let CI (~4 min) be the real gate for clippy + tests.
#
# This machine is slow at any cargo build, so the default hook runs ONLY the
# no-compile checks (`cargo fmt --check` + `git diff --check`) — ~1-2s. Clippy and
# the test suite run in CI on every push (.github/workflows/ci.yml).
#
# Enable once per clone with:
#   git config core.hooksPath .githooks
#
# Want the heavier local gate before a risky push? Opt in:
#   MODAL_RUST_FULL_PUSH=1 git push   # fmt + clippy + core-crate tests + whitespace
# Or run the complete CI mirror by hand:  scripts/ci-gate.sh
# Or skip the hook entirely:             git push --no-verify
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

RUST_TOOLCHAIN="1.96.0" # keep in lockstep with ci.yml + rust-toolchain.toml

run() {
  echo "==> $*"
  "$@"
}

# Always: the no-compile checks (instant).
run cargo +"$RUST_TOOLCHAIN" fmt --check
run git diff --check

if [[ "${MODAL_RUST_FULL_PUSH:-0}" != "1" ]]; then
  echo "pre-push: fast checks green (fmt + whitespace). Clippy + tests run in CI; MODAL_RUST_FULL_PUSH=1 to run them locally."
  exit 0
fi

# Opt-in heavy gate: clippy (full lint surface) + core-crate tests (skip the ~28
# example crates — CI runs those; they make a local `cargo test` take ~1h here).
run cargo +"$RUST_TOOLCHAIN" clippy --all-targets -- -D warnings
run cargo +"$RUST_TOOLCHAIN" clippy -p modal-rust -p modal-rust-macros -- -D warnings
run cargo +"$RUST_TOOLCHAIN" test \
  -p modal-rust \
  -p modal-rust-sdk \
  -p modal-rust-runtime \
  -p modal-rust-cli \
  -p modal-rust-macros

echo "pre-push: full local gate green. (Example crates still only run in CI / scripts/ci-gate.sh.)"

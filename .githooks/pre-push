#!/usr/bin/env bash
# pre-push — catch the regressions that matter before they reach CI, fast.
#
# Runs the FULL fmt + clippy gate (cheap) plus `cargo test` on the FIVE CORE
# crates only. The ~28 example test crates are deliberately skipped here: they
# dominate the wall-clock (each links the facade and exercises the CLI/build
# path) and make a full local `cargo test` take ~1h on a cold/contended machine,
# while CI runs everything in ~4min. CI remains the complete gate.
#
# Enable once per clone with:
#   git config core.hooksPath .githooks
#
# Tradeoff to know: a regression that lives ONLY in an example crate (e.g. a
# stale example test asserting old image output) will NOT be caught here — CI
# catches it. Before pushing something that touches examples or image/manifest
# rendering, run the full mirror yourself: scripts/ci-gate.sh
#
# Fast path: set MODAL_RUST_FAST_PUSH=1 to run only fmt + clippy (no tests).
#   MODAL_RUST_FAST_PUSH=1 git push
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

RUST_TOOLCHAIN="1.96.0" # keep in lockstep with ci.yml + rust-toolchain.toml

run() {
  echo "==> $*"
  "$@"
}

# fmt + clippy (the full CI lint surface — cheap, always run).
run cargo +"$RUST_TOOLCHAIN" fmt --check
run cargo +"$RUST_TOOLCHAIN" clippy --all-targets -- -D warnings
run cargo +"$RUST_TOOLCHAIN" clippy -p modal-rust -p modal-rust-macros -- -D warnings

if [[ "${MODAL_RUST_FAST_PUSH:-0}" == "1" ]]; then
  echo "pre-push: FAST mode (MODAL_RUST_FAST_PUSH=1) — SKIPPING tests."
  exit 0
fi

# Tests: the five core crates only (skip the slow example crates — CI runs them).
run cargo +"$RUST_TOOLCHAIN" test \
  -p modal-rust \
  -p modal-rust-sdk \
  -p modal-rust-runtime \
  -p modal-rust-cli \
  -p modal-rust-macros

# Whitespace (matches ci.yml's Check Whitespace step).
run git diff --check

echo "pre-push: core gate green. Example crates are NOT tested here — run scripts/ci-gate.sh for the full CI mirror."
